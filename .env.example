OPENROUTER_ARCHITECT_DESIGN=arcee-ai/trinity-large-preview:free,liquid/lfm-2.5-1.2b-thinking:free,meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_SECURITY_QUALITY=z-ai/glm-4.5-air:free,nvidia/nemotron-3-nano-30b-a3b:free,nvidia/nemotron-nano-9b-v2:free,nvidia/nemotron-nano-12b-v2-vl:free,google/gemma-4-31b-it:free,google/gemma-4-26b-a4b-it:free,google/gemma-3-27b-it:free,google/gemma-3-4b-it:free,google/gemma-3-12b-it:free,google/gemma-3n-e2b-it:free,google/gemma-3n-e4b-it:free
